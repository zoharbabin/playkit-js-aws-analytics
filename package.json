{
  "name": "@playkit-js/playkit-js-aws-analytics",
  "version": "1.0.0",
  "description": "Kaltura Player plugin that replicates AWS TV video analytics via CustomEvent bridge to the Libra framework",
  "main": "dist/playkit-aws-analytics.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "license": "AGPL-3.0",
  "keywords": [
    "kaltura",
    "player",
    "aws",
    "analytics",
    "playkit-js"
  ],
  "scripts": {
    "serve": "webpack serve --open --mode development",
    "watch": "webpack --mode development --watch",
    "build:prod": "webpack --mode production",
    "build": "npm run build:prod",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/ --ext .js --ext .ts",
    "lint:fix": "npm run lint -- --fix",
    "clean": "rimraf ./dist",
    "prebuild": "npm run clean",
    "cy:open": "cypress open",
    "cy:run:chrome": "cypress run --browser chrome --config video=false",
    "test:prepare": "npm run build && copyfiles -f ./dist/playkit-aws-analytics.js ./dist/playkit-aws-analytics.js.map ./cypress/public",
    "test:watch": "npm run test:prepare && npm run cy:open",
    "test": "npm run test:prepare && npm run cy:run:chrome"
  },
  "devDependencies": {
    "@babel/core": "^7.23.7",
    "@babel/plugin-proposal-decorators": "^7.10.5",
    "@babel/plugin-transform-react-jsx": "^7.23.4",
    "@babel/plugin-transform-runtime": "^7.23.7",
    "@babel/preset-env": "^7.23.8",
    "@babel/preset-typescript": "^7.23.3",
    "@babel/runtime": "^7.23.8",
    "@playkit-js/browserslist-config": "1.0.8",
    "@playkit-js/kaltura-player-js": "^3.17.9-canary.0-0c8731f",
    "@playkit-js/webpack-common": "^1.0.3",
    "@types/chai": "^4.3.3",
    "@types/mocha": "^9.1.1",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "babel-loader": "^9.1.3",
    "chai": "^4.3.6",
    "css-loader": "^6.9.0",
    "eslint": "^8.56.0",
    "eslint-config-preact": "^1.3.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-mocha": "^10.2.0",
    "eslint-plugin-prettier": "^5.1.3",
    "mocha": "^10.2.0",
    "prettier": "^3.2.2",
    "sinon": "^14.0.0",
    "standard-version": "^9.5.0",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1",
    "cypress": "14.1.0",
    "eslint-plugin-cypress": "^3.3.0",
    "copyfiles": "^2.4.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "browserslist": [
    "extends @playkit-js/browserslist-config"
  ]
}
